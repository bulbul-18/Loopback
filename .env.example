# Copy this file to .env and fill in your details

# --- Database ---
# Local Postgres example: postgres://postgres:password@localhost:5432/loopback
# Hosted providers (Render, Railway, Supabase) give you a full connection string.
DATABASE_URL=postgres://user:password@localhost:5432/loopback
# Set to "true" if your host requires SSL (most hosted providers do; local usually doesn't)
DATABASE_SSL=false

# --- Auth ---
# Any long random string -- used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# --- Google sign-in (optional) ---
# Leave these blank to disable "Sign in with Google" and use email/password only.
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Email (for password reset links) ---
# Get a free API key at https://resend.com (100 emails/day free tier)
RESEND_API_KEY=
# Must be a verified sender on your Resend account. Their shared test
# address works for development but can usually only send to the email
# you signed up to Resend with -- verify your own domain to send to anyone.
EMAIL_FROM=LoopBack <onboarding@resend.dev>
# Used to build the link inside reset emails -- your real domain once deployed
APP_URL=http://localhost:3000

# --- Server ---
PORT=3000
NODE_ENV=development